# Quartus build outputs
quartus/**/db/
quartus/**/incremental_db/
quartus/**/output_files/
quartus/**/tmp-clearbox/
quartus/**/qdb/
quartus/**/dni/
quartus/**/synth_dumps/
*.qws
*.qarlog
*.rpt.bak
*.sof
*.pof
*.jic
*.rbf

# Per-run Quartus reports/logs/state left directly in a project dir by `quartus_sh --flow
# compile` (issue #1: these are not covered by the directory-shaped ignores above, and appear
# even for the trivial smoke project — .rpt/.summary per stage, .pin from the Fitter, .sld from
# the Assembler/SignalTap, .done as a flow completion marker, serv_req_info.txt from licensing).
quartus/**/*.rpt
quartus/**/*.summary
quartus/**/*.pin
quartus/**/*.sld
quartus/**/*.done
quartus/**/serv_req_info.txt

# Simulation
sim/**/obj_dir/
sim/**/obj_*/
sim/**/*.log
sim/**/work/
*.vcd
*.fst
*.wlf
transcript

# Model / dataset artifacts (regenerated by sw/model_prep, never committed)
models/downloads/
models/onnx/
models/ir/
models/compiled/
*.onnx
*.tflite
*.bin
*.xml.bak
*.mif
datasets/
*.recimg

# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
.pytest_cache/

# Editors / OS
.vscode/
.idea/
*.swp
.DS_Store
