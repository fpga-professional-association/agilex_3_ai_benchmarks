# Quartus build outputs
quartus/**/db/
quartus/**/incremental_db/
quartus/**/output_files/
quartus/**/tmp-clearbox/
quartus/**/qdb/
quartus/**/dni/
quartus/**/synth_dumps/
*.qws
*.qarlog
*.rpt.bak
*.sof
*.pof
*.jic
*.rbf

# Per-run Quartus reports/logs/state left directly in a project dir by `quartus_sh --flow
# compile` (issue #1: these are not covered by the directory-shaped ignores above, and appear
# even for the trivial smoke project — .rpt/.summary per stage, .pin from the Fitter, .sld from
# the Assembler/SignalTap, .done as a flow completion marker, serv_req_info.txt from licensing).
quartus/**/*.rpt
quartus/**/*.summary
quartus/**/*.pin
quartus/**/*.sld
quartus/**/*.done
quartus/**/serv_req_info.txt
quartus/**/*.qws
quartus/**/*.jdi
quartus/**/*.sof

# L1 sweep (issue #11): the .qpf and 24 per-revision .qsf are derived artifacts, generated by
# scripts/sweep_l1.py from the committed harness/SDCs/script. Regenerate with the sweep driver.
quartus/l1_sweep/*.qsf
quartus/l1_sweep/*.qpf

# Simulation
sim/**/obj_dir/
sim/**/obj_*/
sim/**/*.log
sim/**/work/
*.vcd
*.fst
*.wlf
transcript

# Model / dataset artifacts (regenerated by sw/model_prep, never committed)
models/downloads/
models/onnx/
models/ir/
models/compiled/
*.onnx
*.tflite
*.bin
*.xml.bak
*.mif
datasets/
*.recimg

# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
.pytest_cache/

# Editors / OS
.vscode/
.idea/
*.swp
.DS_Store

# PH3 CoreDLA example-design generation (AI-Suite output, regenerable via dla_build_example_design.py)
_ph3_ed/
_ph3_ed_hyperram/

# Quartus/qsys build databases left at the repo root when tools are run from here
# (regenerable; the quartus/**/ ignores above only catch them under a project dir).
/qdb/
/dni/
compiled_model_dir/
scratch/
models/scratch_*/
models/scratch/
sw/hls4ml/hls4ml_prj*/
sw/hls4ml/*.onnx
venv-hls4ml/
